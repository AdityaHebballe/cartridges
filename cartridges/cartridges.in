import gettext
import locale
import os
import signal
import site
import sys
from time import perf_counter
from pathlib import Path
from platform import system

VERSION = "@VERSION@"
PROFILE_START = bool(os.getenv("CARTRIDGES_PROFILE_STARTUP"))
PROFILE_STARTED_AT = perf_counter()
PROFILE_LAST_MARK = PROFILE_STARTED_AT

if PROFILE_START:
    os.environ.setdefault("CARTRIDGES_NON_UNIQUE", "1")


def profile_mark(name):
    global PROFILE_LAST_MARK  # pylint: disable=global-statement

    if not PROFILE_START:
        return

    now = perf_counter()
    print(
        "[startup] "
        f"launcher {name}: +{(now - PROFILE_LAST_MARK) * 1000:.1f} ms "
        f"({(now - PROFILE_STARTED_AT) * 1000:.1f} ms total)",
        file=sys.stderr,
    )
    PROFILE_LAST_MARK = now

if os.name == "nt":
    PKGDATADIR = os.path.join(os.path.dirname(__file__), "..", "share", "cartridges")
else:
    PKGDATADIR = "@pkgdatadir@"
    LOCALEDIR = "@localedir@"

sys.path.insert(1, PKGDATADIR)
user_site = site.getusersitepackages()
if isinstance(user_site, str):
    user_site = (user_site,)
sys.path = [path for path in sys.path if path not in user_site]
signal.signal(signal.SIGINT, signal.SIG_DFL)
profile_mark("paths ready")

if system() == "Linux":
    locale.bindtextdomain("cartridges", LOCALEDIR)
    locale.textdomain("cartridges")
    gettext.install("cartridges", LOCALEDIR, names=['ngettext'])
else:
    gettext.install("cartridges", names=['ngettext'])
profile_mark("gettext ready")

if __name__ == "__main__":
    from gi.repository import Gio, GLib
    profile_mark("gi imported")

    try:
        # For a macOS application bundle
        resource = Gio.Resource.load(
            str(Path(__file__).parent / "Resources" / "cartridges.gresource")
        )
    except GLib.GError:
        resource = Gio.Resource.load(os.path.join(PKGDATADIR, "cartridges.gresource"))
    resource._register()  # pylint: disable=protected-access
    profile_mark("resources registered")

    from cartridges import main
    profile_mark("main imported")

    sys.exit(main.main(VERSION))
